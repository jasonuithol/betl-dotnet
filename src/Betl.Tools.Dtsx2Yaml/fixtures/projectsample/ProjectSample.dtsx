<?xml version="1.0"?>
<!--
  Project-sample DTSX fixture for betl-dtsx2yaml.

  This fixture is laid out the way a real SSDT Project Deployment
  Model project is on disk:
      Warehouse.conmgr     - project connection manager (sibling)
      Project.params       - project parameters (sibling)
      ProjectSample.dtsx   - this file, referencing both by name

  When betl-dtsx2yaml is pointed at this .dtsx it auto-discovers
  the siblings and merges them into the package model. The converter
  therefore needs to handle:
    1. external .conmgr files (the package has NO embedded
       <DTS:ConnectionManagers> block)
    2. <SSIS:Parameter> blocks with System.TypeCode encoding
       (DataType=18 here = String, not VARENUM's UInt16)
    3. <DTS:PropertyExpression> overriding a static SqlStatementSource
       with a runtime SSIS expression that splices @[$Project::BatchTag]
    4. STOCK:SEQUENCE container (older SSDT spelling)
    5. Microsoft.SQLServerDestination component, which we route to
       mssql.upsert per the project's "just write to SQL Server"
       requirement.
-->
<DTS:Executable xmlns:DTS="www.microsoft.com/SqlServer/Dts"
  DTS:refId="Package"
  DTS:CreationName="Microsoft.Package"
  DTS:DTSID="{aaaaaaaa-bbbb-cccc-dddd-eeeeeeee0001}"
  DTS:ExecutableType="Microsoft.Package"
  DTS:LocaleID="1033"
  DTS:ObjectName="ProjectSample"
  DTS:PackageType="5"
  DTS:VersionBuild="1"
  DTS:VersionGUID="{aaaaaaaa-bbbb-cccc-dddd-eeeeeeee0002}">

  <!--
    NO <DTS:ConnectionManagers> here on purpose — the connection
    lives in the sibling .conmgr file. The Pipeline below references
    it via connectionManagerRefId="Project.ConnectionManagers[Warehouse]".
  -->

  <DTS:Executables>

    <DTS:Executable
      DTS:refId="Package\Migrate"
      DTS:CreationName="STOCK:SEQUENCE"
      DTS:Description="Sequence Container"
      DTS:DTSID="{aaaaaaaa-bbbb-cccc-dddd-ffffffff0001}"
      DTS:ExecutableType="STOCK:SEQUENCE"
      DTS:ObjectName="Migrate">
      <DTS:Variables/>
      <DTS:Executables>

        <DTS:Executable
          DTS:refId="Package\Migrate\Tag Batch"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:DelayValidation="True"
          DTS:DTSID="{aaaaaaaa-bbbb-cccc-dddd-ffffffff0002}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:ObjectName="Tag Batch">
          <DTS:Variables/>
          <DTS:PropertyExpression
            DTS:Name="SqlStatementSource">"INSERT INTO dbo.BatchLog(tag, row_limit) VALUES ('" + @[$Project::BatchTag] + "', " + (DT_WSTR, 12)@[$Project::RowLimit] + ")"</DTS:PropertyExpression>
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
              SQLTask:Connection="{75150A3A-E962-4FE0-ADDE-188E64F257F0}"
              SQLTask:SqlStatementSource="INSERT INTO dbo.BatchLog(tag, row_limit) VALUES ('placeholder', 0)" />
          </DTS:ObjectData>
        </DTS:Executable>

        <DTS:Executable
          DTS:refId="Package\Migrate\Copy Orders"
          DTS:CreationName="Microsoft.Pipeline"
          DTS:DelayValidation="True"
          DTS:DTSID="{aaaaaaaa-bbbb-cccc-dddd-ffffffff0003}"
          DTS:ExecutableType="Microsoft.Pipeline"
          DTS:ObjectName="Copy Orders">
          <DTS:Variables/>
          <DTS:ObjectData>
            <pipeline DefaultBufferMaxRows="10000" DefaultBufferSize="10485760" version="1">
              <components>

                <component
                  refId="Package\Migrate\Copy Orders\OleSource"
                  componentClassID="Microsoft.OLEDBSource"
                  description="OLE DB Source"
                  name="OleSource"
                  usesDispositions="true"
                  version="7">
                  <properties>
                    <property dataType="System.Int32"  name="AccessMode">2</property>
                    <property dataType="System.String" name="OpenRowset"></property>
                    <property dataType="System.String" name="OpenRowsetVariable"></property>
                    <property dataType="System.String" name="SqlCommand">SELECT id, amount FROM dbo.Orders</property>
                    <property dataType="System.String" name="SqlCommandVariable"></property>
                    <property dataType="System.String" name="ParameterMapping"></property>
                  </properties>
                  <connections>
                    <connection
                      refId="Package\Migrate\Copy Orders\OleSource.Connections[OleDbConnection]"
                      connectionManagerID="{75150A3A-E962-4FE0-ADDE-188E64F257F0}:external"
                      connectionManagerRefId="Project.ConnectionManagers[Warehouse]"
                      name="OleDbConnection"/>
                  </connections>
                  <outputs>
                    <output
                      refId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Output]"
                      name="OLE DB Source Output">
                      <outputColumns>
                        <outputColumn
                          refId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Output].Columns[id]"
                          dataType="i8"
                          errorOrTruncationOperation="Conversion"
                          errorRowDisposition="FailComponent"
                          externalMetadataColumnId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Output].ExternalColumns[id]"
                          lineageId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Output].Columns[id]"
                          name="id"
                          truncationRowDisposition="FailComponent"/>
                        <outputColumn
                          refId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Output].Columns[amount]"
                          dataType="i8"
                          errorOrTruncationOperation="Conversion"
                          errorRowDisposition="FailComponent"
                          externalMetadataColumnId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Output].ExternalColumns[amount]"
                          lineageId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Output].Columns[amount]"
                          name="amount"
                          truncationRowDisposition="FailComponent"/>
                      </outputColumns>
                      <externalMetadataColumns isUsed="True">
                        <externalMetadataColumn
                          refId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Output].ExternalColumns[id]"
                          dataType="i8" name="id"/>
                        <externalMetadataColumn
                          refId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Output].ExternalColumns[amount]"
                          dataType="i8" name="amount"/>
                      </externalMetadataColumns>
                    </output>
                    <output
                      refId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Error Output]"
                      isErrorOut="true"
                      name="OLE DB Source Error Output">
                      <outputColumns>
                        <outputColumn
                          refId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Error Output].Columns[id]"
                          dataType="i8"
                          lineageId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Error Output].Columns[id]"
                          name="id"/>
                        <outputColumn
                          refId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Error Output].Columns[amount]"
                          dataType="i8"
                          lineageId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Error Output].Columns[amount]"
                          name="amount"/>
                        <outputColumn
                          refId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Error Output].Columns[ErrorCode]"
                          dataType="i4"
                          lineageId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Error Output].Columns[ErrorCode]"
                          name="ErrorCode"
                          specialFlags="1"/>
                        <outputColumn
                          refId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Error Output].Columns[ErrorColumn]"
                          dataType="i4"
                          lineageId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Error Output].Columns[ErrorColumn]"
                          name="ErrorColumn"
                          specialFlags="2"/>
                      </outputColumns>
                      <externalMetadataColumns/>
                    </output>
                  </outputs>
                </component>

                <component
                  refId="Package\Migrate\Copy Orders\SqlDest"
                  componentClassID="Microsoft.SQLServerDestination"
                  description="SQL Server Destination"
                  name="SqlDest"
                  usesDispositions="true"
                  version="5">
                  <properties>
                    <property dataType="System.Int32"   name="DefaultCodePage">1252</property>
                    <property dataType="System.Boolean" name="AlwaysUseDefaultCodePage">false</property>
                    <property dataType="System.String"  name="BulkInsertTableName">[dbo].[Orders_Staged]</property>
                    <property dataType="System.Boolean" name="BulkInsertKeepIdentity">true</property>
                    <property dataType="System.Boolean" name="BulkInsertFireTriggers">false</property>
                    <property dataType="System.Boolean" name="BulkInsertTablock">true</property>
                  </properties>
                  <connections>
                    <connection
                      refId="Package\Migrate\Copy Orders\SqlDest.Connections[OleDbConnection]"
                      connectionManagerID="{75150A3A-E962-4FE0-ADDE-188E64F257F0}:external"
                      connectionManagerRefId="Project.ConnectionManagers[Warehouse]"
                      name="OleDbConnection"/>
                  </connections>
                  <inputs>
                    <input
                      refId="Package\Migrate\Copy Orders\SqlDest.Inputs[SQL Server Destination Input]"
                      hasSideEffects="true"
                      name="SQL Server Destination Input">
                      <inputColumns>
                        <inputColumn
                          refId="Package\Migrate\Copy Orders\SqlDest.Inputs[SQL Server Destination Input].Columns[id]"
                          cachedDataType="i8"
                          cachedName="id"
                          lineageId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Output].Columns[id]"/>
                        <inputColumn
                          refId="Package\Migrate\Copy Orders\SqlDest.Inputs[SQL Server Destination Input].Columns[amount]"
                          cachedDataType="i8"
                          cachedName="amount"
                          lineageId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Output].Columns[amount]"/>
                      </inputColumns>
                      <externalMetadataColumns/>
                    </input>
                  </inputs>
                </component>

              </components>
              <paths>
                <path
                  refId="Package\Migrate\Copy Orders.Paths[SrcToDest]"
                  endId="Package\Migrate\Copy Orders\SqlDest.Inputs[SQL Server Destination Input]"
                  name="SrcToDest"
                  startId="Package\Migrate\Copy Orders\OleSource.Outputs[OLE DB Source Output]"/>
              </paths>
            </pipeline>
          </DTS:ObjectData>
        </DTS:Executable>

      </DTS:Executables>

      <DTS:PrecedenceConstraints>
        <DTS:PrecedenceConstraint
          DTS:refId="Package\Migrate.PrecedenceConstraints[TagThenCopy]"
          DTS:CreationName=""
          DTS:DTSID="{aaaaaaaa-bbbb-cccc-dddd-ffffffff0099}"
          DTS:From="Package\Migrate\Tag Batch"
          DTS:LogicalAnd="True"
          DTS:ObjectName="Tag -> Copy"
          DTS:To="Package\Migrate\Copy Orders"/>
      </DTS:PrecedenceConstraints>

    </DTS:Executable>

  </DTS:Executables>
</DTS:Executable>
