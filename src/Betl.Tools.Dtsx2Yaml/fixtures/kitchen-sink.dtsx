<?xml version="1.0"?>
<!--
  Full-fidelity DTSX fixture for betl-dtsx2yaml.

  Unlike the other fixtures in this directory (which strip DTSX down to
  the attribute subset the converter actually reads), this package is
  written to the exact shape that a real SSDT-generated package uses,
  and validates clean against the SQL Server 2022 dtexec on Linux that
  ships with the mcp-ssis service:

      validate_package(path="dtsx2yaml-fixtures/kitchen-sink.dtsx")
      → VALIDATE VALID ✓

  Shape:
    Connection:      1 OLEDB to a SQL Server, MSOLEDBSQL provider
    Variables:       BatchTag (string, DataType=8/VT_BSTR)
                     MinAmount (int,    DataType=3/VT_I4)
                     SkipExecSql (bool, DataType=11/VT_BOOL)
    Executables:     1 ExecuteSQL Task ("Truncate Stage")
                     1 Data Flow ("Extract Orders") with
                       OLEDB Source → Derived Column → Row Count
    Constraints:     Truncate → Extract (Success)

  This fixture is the regression backstop for "what real SSDT emits".
  Pair it with the minimal fixtures (which test parser tolerance);
  this one tests format fidelity.
-->
<DTS:Executable
    xmlns:DTS="www.microsoft.com/SqlServer/Dts"
    DTS:refId="Package"
    DTS:CreationName="Microsoft.Package"
    DTS:DTSID="{ffffffff-eeee-dddd-cccc-bbbbbbbb0001}"
    DTS:ExecutableType="Microsoft.Package"
    DTS:LocaleID="1033"
    DTS:ObjectName="KitchenSink"
    DTS:PackageType="5"
    DTS:VersionBuild="0"
    DTS:VersionGUID="{ffffffff-eeee-dddd-cccc-bbbbbbbb0002}">

  <DTS:ConnectionManagers>
    <DTS:ConnectionManager
        DTS:refId="Package.ConnectionManagers[Warehouse]"
        DTS:CreationName="OLEDB"
        DTS:DTSID="{ffffffff-eeee-dddd-cccc-cccccccc0001}"
        DTS:ObjectName="Warehouse">
      <DTS:ObjectData>
        <DTS:ConnectionManager DTS:ConnectionString="Data Source=db.example.com;Initial Catalog=Sales;Integrated Security=SSPI;Provider=MSOLEDBSQL;"/>
      </DTS:ObjectData>
    </DTS:ConnectionManager>
  </DTS:ConnectionManagers>

  <DTS:Variables>
    <DTS:Variable
        DTS:CreationName="User::BatchTag"
        DTS:DTSID="{ffffffff-eeee-dddd-cccc-dddddddd0001}"
        DTS:Namespace="User"
        DTS:ObjectName="BatchTag">
      <DTS:VariableValue DTS:DataType="8">nightly</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
        DTS:CreationName="User::MinAmount"
        DTS:DTSID="{ffffffff-eeee-dddd-cccc-dddddddd0002}"
        DTS:Namespace="User"
        DTS:ObjectName="MinAmount">
      <DTS:VariableValue DTS:DataType="3">100</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
        DTS:CreationName="User::SkipExecSql"
        DTS:DTSID="{ffffffff-eeee-dddd-cccc-dddddddd0003}"
        DTS:Namespace="User"
        DTS:ObjectName="SkipExecSql">
      <DTS:VariableValue DTS:DataType="11">False</DTS:VariableValue>
    </DTS:Variable>
  </DTS:Variables>

  <DTS:Executables>

    <DTS:Executable
        DTS:refId="Package\TruncateStage"
        DTS:CreationName="Microsoft.ExecuteSQLTask"
        DTS:DelayValidation="True"
        DTS:DTSID="{ffffffff-eeee-dddd-cccc-eeeeeeee0001}"
        DTS:ExecutableType="Microsoft.ExecuteSQLTask"
        DTS:ObjectName="Truncate Stage">
      <DTS:Variables/>
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
            xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
            SQLTask:Connection="{ffffffff-eeee-dddd-cccc-cccccccc0001}"
            SQLTask:SqlStatementSource="TRUNCATE TABLE stage.Orders;"/>
      </DTS:ObjectData>
    </DTS:Executable>

    <DTS:Executable
        DTS:refId="Package\ExtractOrders"
        DTS:CreationName="Microsoft.Pipeline"
        DTS:DelayValidation="True"
        DTS:DTSID="{ffffffff-eeee-dddd-cccc-eeeeeeee0002}"
        DTS:ExecutableType="Microsoft.Pipeline"
        DTS:ObjectName="Extract Orders">
      <DTS:Variables/>
      <DTS:ObjectData>
        <pipeline DefaultBufferMaxRows="10000" DefaultBufferSize="10485760" version="1">
          <components>

            <component
                refId="Package\ExtractOrders\OleSource"
                componentClassID="Microsoft.OLEDBSource"
                contactInfo=""
                description="OLE DB Source"
                name="OleSource"
                usesDispositions="true"
                version="7">
              <properties>
                <property dataType="System.Int32"  name="AccessMode">2</property>
                <property dataType="System.String" name="OpenRowset"></property>
                <property dataType="System.String" name="OpenRowsetVariable"></property>
                <property dataType="System.String" name="SqlCommand">SELECT id, amount FROM dbo.Orders</property>
                <property dataType="System.String" name="SqlCommandVariable"></property>
                <property dataType="System.String" name="ParameterMapping"></property>
              </properties>
              <connections>
                <connection
                    refId="Package\ExtractOrders\OleSource.Connections[OleDbConnection]"
                    connectionManagerID="Package.ConnectionManagers[Warehouse]"
                    connectionManagerRefId="Package.ConnectionManagers[Warehouse]"
                    description=""
                    name="OleDbConnection"/>
              </connections>
              <outputs>
                <output
                    refId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Output]"
                    name="OLE DB Source Output">
                  <outputColumns>
                    <outputColumn
                        refId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Output].Columns[id]"
                        dataType="i8"
                        errorOrTruncationOperation="Conversion"
                        errorRowDisposition="FailComponent"
                        externalMetadataColumnId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Output].ExternalColumns[id]"
                        lineageId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Output].Columns[id]"
                        name="id"
                        truncationRowDisposition="FailComponent"/>
                    <outputColumn
                        refId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Output].Columns[amount]"
                        dataType="i8"
                        errorOrTruncationOperation="Conversion"
                        errorRowDisposition="FailComponent"
                        externalMetadataColumnId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Output].ExternalColumns[amount]"
                        lineageId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Output].Columns[amount]"
                        name="amount"
                        truncationRowDisposition="FailComponent"/>
                  </outputColumns>
                  <externalMetadataColumns isUsed="True">
                    <externalMetadataColumn
                        refId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Output].ExternalColumns[id]"
                        dataType="i8"
                        name="id"/>
                    <externalMetadataColumn
                        refId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Output].ExternalColumns[amount]"
                        dataType="i8"
                        name="amount"/>
                  </externalMetadataColumns>
                </output>
                <output
                    refId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Error Output]"
                    isErrorOut="true"
                    name="OLE DB Source Error Output">
                  <outputColumns>
                    <outputColumn
                        refId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Error Output].Columns[id]"
                        dataType="i8"
                        lineageId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Error Output].Columns[id]"
                        name="id"/>
                    <outputColumn
                        refId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Error Output].Columns[amount]"
                        dataType="i8"
                        lineageId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Error Output].Columns[amount]"
                        name="amount"/>
                    <outputColumn
                        refId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Error Output].Columns[ErrorCode]"
                        dataType="i4"
                        lineageId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Error Output].Columns[ErrorCode]"
                        name="ErrorCode"
                        specialFlags="1"/>
                    <outputColumn
                        refId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Error Output].Columns[ErrorColumn]"
                        dataType="i4"
                        lineageId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Error Output].Columns[ErrorColumn]"
                        name="ErrorColumn"
                        specialFlags="2"/>
                  </outputColumns>
                  <externalMetadataColumns/>
                </output>
              </outputs>
            </component>

            <component
                refId="Package\ExtractOrders\Derive"
                componentClassID="Microsoft.DerivedColumn"
                contactInfo=""
                description="Derived Column"
                name="Derive"
                usesDispositions="true">
              <inputs>
                <input
                    refId="Package\ExtractOrders\Derive.Inputs[Derived Column Input]"
                    name="Derived Column Input">
                  <inputColumns>
                    <inputColumn
                        refId="Package\ExtractOrders\Derive.Inputs[Derived Column Input].Columns[amount]"
                        cachedDataType="i8"
                        cachedName="amount"
                        lineageId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Output].Columns[amount]"/>
                  </inputColumns>
                  <externalMetadataColumns/>
                </input>
              </inputs>
              <outputs>
                <output
                    refId="Package\ExtractOrders\Derive.Outputs[Derived Column Output]"
                    name="Derived Column Output"
                    synchronousInputId="Package\ExtractOrders\Derive.Inputs[Derived Column Input]"
                    exclusionGroup="1">
                  <outputColumns>
                    <outputColumn
                        refId="Package\ExtractOrders\Derive.Outputs[Derived Column Output].Columns[amount_plus_one]"
                        dataType="i8"
                        errorOrTruncationOperation="Computation"
                        errorRowDisposition="FailComponent"
                        lineageId="Package\ExtractOrders\Derive.Outputs[Derived Column Output].Columns[amount_plus_one]"
                        name="amount_plus_one"
                        truncationRowDisposition="FailComponent">
                      <properties>
                        <property dataType="System.String" name="Expression">[amount] + (DT_I8)1</property>
                        <property dataType="System.String" name="FriendlyExpression">[amount] + (DT_I8)1</property>
                      </properties>
                    </outputColumn>
                  </outputColumns>
                  <externalMetadataColumns/>
                </output>
                <output
                    refId="Package\ExtractOrders\Derive.Outputs[Derived Column Error Output]"
                    name="Derived Column Error Output"
                    synchronousInputId="Package\ExtractOrders\Derive.Inputs[Derived Column Input]"
                    isErrorOut="true"
                    exclusionGroup="1">
                  <outputColumns>
                    <outputColumn
                        refId="Package\ExtractOrders\Derive.Outputs[Derived Column Error Output].Columns[ErrorCode]"
                        dataType="i4"
                        lineageId="Package\ExtractOrders\Derive.Outputs[Derived Column Error Output].Columns[ErrorCode]"
                        name="ErrorCode"
                        specialFlags="1"/>
                    <outputColumn
                        refId="Package\ExtractOrders\Derive.Outputs[Derived Column Error Output].Columns[ErrorColumn]"
                        dataType="i4"
                        lineageId="Package\ExtractOrders\Derive.Outputs[Derived Column Error Output].Columns[ErrorColumn]"
                        name="ErrorColumn"
                        specialFlags="2"/>
                  </outputColumns>
                  <externalMetadataColumns/>
                </output>
              </outputs>
            </component>

            <component
                refId="Package\ExtractOrders\RowCount"
                componentClassID="Microsoft.RowCount"
                contactInfo=""
                description="Row Count"
                name="RowCount"
                usesDispositions="true">
              <properties>
                <property dataType="System.String" name="VariableName">User::MinAmount</property>
              </properties>
              <inputs>
                <input
                    refId="Package\ExtractOrders\RowCount.Inputs[Row Count Input 1]"
                    hasSideEffects="true"
                    name="Row Count Input 1">
                  <inputColumns>
                    <inputColumn
                        refId="Package\ExtractOrders\RowCount.Inputs[Row Count Input 1].Columns[id]"
                        cachedDataType="i8"
                        cachedName="id"
                        lineageId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Output].Columns[id]"/>
                    <inputColumn
                        refId="Package\ExtractOrders\RowCount.Inputs[Row Count Input 1].Columns[amount]"
                        cachedDataType="i8"
                        cachedName="amount"
                        lineageId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Output].Columns[amount]"/>
                    <inputColumn
                        refId="Package\ExtractOrders\RowCount.Inputs[Row Count Input 1].Columns[amount_plus_one]"
                        cachedDataType="i8"
                        cachedName="amount_plus_one"
                        lineageId="Package\ExtractOrders\Derive.Outputs[Derived Column Output].Columns[amount_plus_one]"/>
                  </inputColumns>
                  <externalMetadataColumns/>
                </input>
              </inputs>
              <outputs>
                <output
                    refId="Package\ExtractOrders\RowCount.Outputs[Row Count Output 1]"
                    name="Row Count Output 1"
                    synchronousInputId="Package\ExtractOrders\RowCount.Inputs[Row Count Input 1]"/>
              </outputs>
            </component>

          </components>
          <paths>
            <path
                refId="Package\ExtractOrders.Paths[SrcToDerive]"
                endId="Package\ExtractOrders\Derive.Inputs[Derived Column Input]"
                name="SrcToDerive"
                startId="Package\ExtractOrders\OleSource.Outputs[OLE DB Source Output]"/>
            <path
                refId="Package\ExtractOrders.Paths[DeriveToCount]"
                endId="Package\ExtractOrders\RowCount.Inputs[Row Count Input 1]"
                name="DeriveToCount"
                startId="Package\ExtractOrders\Derive.Outputs[Derived Column Output]"/>
          </paths>
        </pipeline>
      </DTS:ObjectData>
    </DTS:Executable>

  </DTS:Executables>

  <DTS:PrecedenceConstraints>
    <DTS:PrecedenceConstraint
        DTS:refId="Package.PrecedenceConstraints[TruncateThenExtract]"
        DTS:CreationName=""
        DTS:DTSID="{ffffffff-eeee-dddd-cccc-aaaaaaaa0001}"
        DTS:From="Package\TruncateStage"
        DTS:LogicalAnd="True"
        DTS:ObjectName="Truncate -> Extract"
        DTS:To="Package\ExtractOrders"
        DTS:Value="0"/>
  </DTS:PrecedenceConstraints>

</DTS:Executable>
